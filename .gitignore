# =============================================================================
# Secrets / 환경 변수
#   .env 는 절대 커밋 금지 (OPENAI_API_KEY, CHATBOT_API_KEY 포함)
#   템플릿은 .env.example 만 추적
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.eggs/
build/
dist/
pip-wheel-metadata/
.installed.cfg

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# 테스트·커버리지
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# Type checker / 린터 캐시
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# 프로젝트 산출물 — 빌드·실행 시 재생성됨, 용량 큼
# =============================================================================
# 빌드된 인덱스 (FAISS + BM25) — scripts/build_indexes.py 가 재생성
vectorstores/

# 평가 결과 — scripts/evaluate.py 가 누적 저장
results/

# 실제 데이터 — 샘플(*_sample.json)만 추적, 본 데이터는 비공개
data/portfolios.json
data/goldset.json
data/*.csv
data/*.parquet
data/*.xlsx

# 로그
*.log
logs/

# =============================================================================
# 모델 캐시 (HuggingFace / sentence-transformers 가 프로젝트 안에 캐시할 경우)
# =============================================================================
.cache/
hf_cache/
models/
*.safetensors
*.bin
*.pt
*.pth

# =============================================================================
# 관측성 / 추적
# =============================================================================
.langsmith/
langsmith_traces/

# =============================================================================
